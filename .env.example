# ===== Datenbank =====
DB_NAME=shop
DB_USER=shop
DB_PASSWORD=change-me

# ===== Discord Bot =====
# Bot-Token aus dem Discord Developer Portal (Bot -> Token)
DISCORD_BOT_TOKEN=
# OAuth2 Client-ID + Secret (OAuth2 -> General)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Server-ID (Rechtsklick auf Server -> ID kopieren). Wenn gesetzt, werden Slash-Commands sofort registriert.
DISCORD_GUILD_ID=
# Rolle, die Admin-Rechte hat (im Bot UND im Dashboard)
DISCORD_ADMIN_ROLE_ID=
# Alternativ/zusätzlich: Discord-User-IDs mit Admin-Rechten, kommagetrennt
ADMIN_IDS=
# Channel für Kauf-/Fehler-Logs
LOG_CHANNEL_ID=
# Kategorie, unter der Ticket-Channels erstellt werden
TICKET_CATEGORY_ID=
# Rolle, die Tickets sehen darf (Support-Team)
SUPPORT_ROLE_ID=

# ===== Branding =====
BRAND_NAME=Crypto Shop
BRAND_COLOR=#5865F2
# Öffentliche URL des Dashboards (wichtig für OAuth-Redirect + Payment-Webhooks)
BASE_URL=http://localhost:8080

# ===== Zahlungen =====
# "nowpayments" für echte Zahlungen, "mock" zum Testen ohne Anbieter
PAYMENT_PROVIDER=mock
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# PayGate (paygate.to) — Kartenzahlung, Auszahlung als USDC (Polygon) auf deine Wallet.
# Kann auch im Dashboard unter Einstellungen -> PayGate gesetzt werden (Dashboard hat Vorrang).
PAYGATE_WALLET=
# Checkout-Anbieter: moonpay | wert | werteu | guardarian | transak
PAYGATE_CHECKOUT_PROVIDER=moonpay

# ===== Sonstiges =====
# true = JEDER eingeloggte Discord-Account sieht das komplette Admin-Dashboard.
# Nur zum Testen/Anschauen — für echten Betrieb unbedingt false!
OPEN_DASHBOARD=false
PORT=8080
# Minuten, bis eine unbezahlte Bestellung verfällt
ORDER_EXPIRY_MINUTES=60
